rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }

    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'mondal.saikat185@gmail.com'
      );
    }
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'status']) &&
             (data.uid == request.auth.uid || isAdmin()) &&
             data.email is string &&
             data.role is string && (data.role == 'student' || data.role == 'admin') &&
             data.status is string &&
             (!('monthlyFee' in data) || data.monthlyFee == null || data.monthlyFee is number || data.monthlyFee is string) &&
             (!('pendingMonths' in data) || data.pendingMonths == null || data.pendingMonths is number || data.pendingMonths is string) &&
             (!('showPaymentNudge' in data) || data.showPaymentNudge is bool) &&
             (!('exemptReason' in data) || data.exemptReason is string || data.exemptReason == null);
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidId(userId) && (userId == request.auth.uid || isAdmin()) &&
                    isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(userId) && isValidUser(incoming()) &&
                    (isAdmin() || (userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(
                      ['updatedAt', 'fullName', 'address', 'dob', 'joinDate', 'phone',
                       'photoURL', 'profilePhotoUrl', 'isProfileComplete', 'batchId', 'activeDevices', 'status']
                    ) && (incoming().status == 'pending' || incoming().status == existing().status)));
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    match /batches/{batchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /notes/{noteId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /batchNotes/{batchNoteId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /exams/{examId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /payments/{paymentId} {
      allow get: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow list: if isSignedIn();
      allow create: if isSignedIn() && (incoming().studentId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /library/{itemId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /libraryChunks/{chunkId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /batchAssignments/{assignmentId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /results/{resultId} {
      allow get: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow list: if isSignedIn();
      allow create: if isSignedIn() && (incoming().studentId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /examSessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() &&
        incoming().diff(existing()).affectedKeys().hasOnly(['participantUids'])
      );
      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
        incoming().diff(existing()).affectedKeys().hasOnly(['presentStudentIds', 'updatedAt']);
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (incoming().senderId == request.auth.uid);
      allow update: if isAdmin() || (
        isSignedIn() &&
        incoming().diff(existing()).affectedKeys().hasOnly(['readers'])
      );
      allow delete: if isAdmin();
    }
  }
}
