rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} { allow read, write: if false; }

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }

    // Helpers
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Entity Definitions
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'status', 'createdAt', 'updatedAt']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 200 &&
             data.role is string && (data.role == 'student' || data.role == 'admin') &&
             data.status is string && (data.status == 'pending' || data.status == 'active' || data.status == 'inactive') &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && (request.auth.uid == userId || isAdmin());
      // Admin list logic - no blanket reads allowed, must specify constraint on client if list is allowed. But admin is global, so a list based on isAdmin is fine if no other constraint
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid &&
                    isValidUser(incoming()) && incoming().createdAt == request.time;
      
      allow update: if isSignedIn() && isValidId(userId) && userId == request.auth.uid &&
                    isValidUser(incoming()) && 
                    (
                      // Admin override
                      isAdmin() ||
                      // Or user action restricted fields (e.g. they can update their own profile subset, but currently we just allow updating updatedAt if nothing else changes)
                      (incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt']) && incoming().updatedAt == request.time)
                    );
    }
  }
}
