function cleanPhone(p) {
  if (p === undefined || p === null) return "";
  var s = String(p).trim();
  if (s.toLowerCase().indexOf('e') !== -1) {
    var num = Number(p);
    if (!isNaN(num)) {
      s = num.toFixed(0);
    }
  }
  if (s.indexOf('.') !== -1) {
    s = s.split('.')[0];
  }
  var digits = s.replace(/\D/g, '');
  if (digits.length >= 10) {
    return digits.slice(-10);
  }
  return digits;
}

